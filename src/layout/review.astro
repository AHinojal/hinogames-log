---
import { Image } from 'astro:assets';
import hg_logo from '../../public/hg_logo.png';

interface Props {
  data: {
    title: string;
    platform: string;
    finishedAt: Date;
    cover: string;
  };
}

const { title, platform, finishedAt, cover } = Astro.props.data;
const base = import.meta.env.BASE_URL;
---

<html lang="en">
	<style>
		.review-header {
      display: flex;
      .cover {
        /* FIXME: Comprobar como cambia con diferentes portadas 25% es prueba por ahora */
        width: 25%;
        margin-right: 20px;
      }
		}
	</style>
	<head>
		<meta charset="utf-8" />
		<link rel="icon" href="hg_favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<title>{title} - HinoGames</title>
	</head>
	<body>
        <header class="review-header">
          <img src={`${base}${cover.replace(/^\//, '')}`} alt={`Portada de ${title}`} class="cover" />
          <div class="meta">
              <h1>{title}</h1>
              <h2 class="platform">{platform}</h2>
              <h3 class="date">{finishedAt.toLocaleDateString('es-ES')}</h3>
          </div>
        </header>

        <article class="review-body">
          <slot />
        </article>
	</body>
</html>
